    "description": "Search indexing, facets, autocomplete",
    "type": "library",
    "license": "proprietary",
    "require": {
        "php": "^8.3",
        "quicktane/core": "@dev",
        "laravel/scout": "^11.0",
        "meilisearch/meilisearch-php": "^1.16"
    },
    "autoload": {
        "psr-4": {
